#!/usr/bin/env bash
# pre-push hook: enforce the install contract and the internal-identifier guard
# before pushing.
# Enable with:  git config core.hooksPath tools/hooks
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# Resolve a *working* python. Skip the Windows Store execution-alias stub under
# WindowsApps (it only prints an install message and exits non-zero), and fall
# back to the `py` launcher on Windows.
PY=()
for c in python3 python; do
    p="$(command -v "$c" 2>/dev/null || true)"
    case "$p" in *WindowsApps*) continue ;; esac
    if [[ -n "$p" ]]; then PY=("$p"); break; fi
done
if [[ ${#PY[@]} -eq 0 ]] && command -v py >/dev/null 2>&1; then
    PY=(py -3)
fi
if [[ ${#PY[@]} -eq 0 ]]; then
    echo "pre-push: python not found -- skipping pre-push checks" >&2
    exit 0
fi
# No-op unless a private denylist is configured (env / ~/.agent-codespaces).
"${PY[@]}" "$ROOT/tools/check-no-internal-identifiers.py"
exec "${PY[@]}" "$ROOT/tools/check-install-contract.py"
