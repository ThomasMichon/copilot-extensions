__pycache__/
*.pyc


*.egg-info/

build/

# Local dev/test virtualenvs and caches (installers use ~/.agent-* venvs)
.venv/
.pytest_cache/
.ruff_cache/

# uv materializes a lockfile on `uv run`/`uv sync`. Plugins that intentionally
# do NOT pin a lockfile must ignore it so it never dirties a worktree and
# blocks push-changes (#28). agent-bridge tracks its own uv.lock on purpose.
/plugins/agent-codespaces/uv.lock
/plugins/agent-worktrees/uv.lock
# The ssh-manager lib (and its vendored copies) does not pin a lockfile either.
/libs/ssh-manager/uv.lock
/plugins/agent-bridge/libs/ssh-manager/uv.lock
/plugins/agent-codespaces/libs/ssh-manager/uv.lock
# The credential-relay lib (and its vendored copies) likewise pins no lockfile.
/libs/credential-relay/uv.lock
/libs/credential-relay/.testvenv/
/plugins/agent-bridge/libs/credential-relay/uv.lock
/plugins/agent-codespaces/libs/credential-relay/uv.lock
/plugins/agent-containers/libs/credential-relay/uv.lock
