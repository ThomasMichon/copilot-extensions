#!/bin/bash
# ado-auth-helper — Credential helper proxy for SSH-tunneled auth
#
# Drop-in replacement for the VS Code extension's ~/ado-auth-helper when
# connecting via SSH. Proxies requests through the SSH RemoteForward tunnel
# back to the local machine's Git Credential Manager.
#
# Supports all hosts — ADO (your Azure DevOps org host, dev.azure.com) and
# GitHub (github.com) — by relaying to the local GCM which has credentials
# for both. This enables dotfiles repo operations over SSH without manual
# token forwarding.
#
# Supports:
#   get              — Git credential helper mode (reads git-credential-protocol from stdin)
#   get-access-token — Returns a raw ADO access token for non-git tools (npm, nuget)
#
# The SSH session must set LC_GIT_CREDENTIAL_RELAY=<port> and forward
# that port with -R <port>:localhost:<port>.
#
# If LC_GIT_CREDENTIAL_RELAY is not set (e.g., in a VS Code session),
# this helper exits immediately, letting the VS Code extension handle auth.

ACTION="${1:-}"
SCOPE="${2:-}"
DEFAULT_RELAY_PORT=9857
RELAY_PORT="${LC_GIT_CREDENTIAL_RELAY:-}"
RELAY_TOKEN="${LC_GIT_CREDENTIAL_RELAY_TOKEN:-}"

# If env var is not set, probe the default port (SSH RemoteForward may be
# active from a codespace-ssh session even though this shell doesn't have
# the env var — e.g., postCreateCommand, cron, systemd, etc.)
if [ -z "$RELAY_PORT" ]; then
    if (echo >/dev/tcp/localhost/$DEFAULT_RELAY_PORT) 2>/dev/null; then
        RELAY_PORT="$DEFAULT_RELAY_PORT"
    else
        exit 1
    fi
fi

case "$ACTION" in
    get)
        # Git credential helper mode — read stdin, proxy through relay
        exec python3 -c "
import socket, sys

port = int(sys.argv[1])
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(10)

try:
    s.connect(('localhost', port))

    # Read stdin until blank line (git credential protocol terminator)
    lines = []
    for line in sys.stdin:
        lines.append(line)
        if line.strip() == '':
            break
    stdin_data = ''.join(lines)

    # Send through relay (no action prefix — server defaults to 'get')
    request = stdin_data
    if not request.endswith('\n\n'):
        request = request.rstrip('\n') + '\n\n'

    s.sendall(request.encode('utf-8'))

    # Read response until blank line or EOF
    s.settimeout(30)
    response = b''
    while True:
        chunk = s.recv(4096)
        if not chunk:
            break
        response += chunk
        if b'\n\n' in response:
            break

    sys.stdout.buffer.write(response)
    sys.stdout.buffer.flush()
except Exception:
    sys.exit(1)
finally:
    s.close()
" "$RELAY_PORT"
        ;;

    get-access-token)
        if [ -n "$SCOPE" ]; then
            # Azure managed-identity scope mode — the official
            # `azure-auth-helper get-access-token "<scope>"` contract. Mint an
            # AAD token for <scope> via the relay's gated get-azure-token action
            # (resolved from the host az identity) and print the bare token.
            exec python3 -c "
import socket, sys

port = int(sys.argv[1])
scope = sys.argv[2]
auth = sys.argv[3]
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(10)

try:
    s.connect(('localhost', port))

    lines = ['get-azure-token', 'scope=' + scope]
    if auth:
        lines.append('auth=' + auth)
    request = '\n'.join(lines) + '\n\n'
    s.sendall(request.encode('utf-8'))

    s.settimeout(30)
    response = b''
    while True:
        chunk = s.recv(4096)
        if not chunk:
            break
        response += chunk
        if b'\n\n' in response:
            break

    # Response is git-credential key=value framing; extract token=.
    token = ''
    for line in response.decode('utf-8').splitlines():
        if line.startswith('token='):
            token = line[len('token='):]
            break
    if token:
        print(token)
    else:
        sys.exit(1)
except Exception:
    sys.exit(1)
finally:
    s.close()
" "$RELAY_PORT" "$SCOPE" "$RELAY_TOKEN"
        fi
        # Direct token mode — return a raw ADO access token for npm, nuget, etc.
        exec python3 -c "
import socket, sys

port = int(sys.argv[1])
s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
s.settimeout(10)

try:
    s.connect(('localhost', port))

    request = 'get-access-token\n\n'
    s.sendall(request.encode('utf-8'))

    s.settimeout(30)
    response = b''
    while True:
        chunk = s.recv(4096)
        if not chunk:
            break
        response += chunk
        if b'\n\n' in response:
            break

    token = response.decode('utf-8').strip()
    if token:
        print(token)
    else:
        sys.exit(1)
except Exception:
    sys.exit(1)
finally:
    s.close()
" "$RELAY_PORT"
        ;;

    *)
        # store/erase — acknowledge silently
        exit 0
        ;;
esac
