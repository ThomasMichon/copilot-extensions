#!/usr/bin/env node
/*
 * ado/azure-auth-helper -- smart wrapper deployed by agent-codespaces.
 *
 * Relay-first: when the SSH credential relay is active (LC_GIT_CREDENTIAL_RELAY
 * set, or the default relay port is reachable) this delegates to the relay
 * client (~/.local/bin/ado-auth-helper-relay), so ADO auth resolves over the
 * SSH RemoteForward tunnel back to the host Git Credential Manager.
 *
 * Otherwise it FALLS BACK by require()-ing the REAL VS Code extension auth
 * helper (ms-codespaces-tools.ado-codespaces-auth, out/auth-helper.js),
 * discovered at runtime. This mirrors how the extension's own shim works
 * (a thin require() of out/auth-helper.js) so VS Code / post-start / terminal
 * auth keeps working even after an SSH session disconnects -- instead of
 * relying on a static backup copy that goes stale when the extension updates.
 *
 * If NEITHER is ready yet -- the relay tunnel is down AND the VS Code helper
 * hasn't initialized (the "reverse order" case: agent-codespaces provisions us
 * first, then VS Code opens and its auth system comes up moments later) -- we do
 * NOT hard-fail. A hard failure makes single-shot callers (setup-agency /
 * external-git) fall through to a plain-git `Username:` prompt that HANGS,
 * stalling postStart. Instead we BLOCK (bounded poll) until the relay or the VS
 * Code helper becomes serviceable, so the caller's one call waits through the
 * window and then succeeds. On timeout we fail QUIETLY (git `get` -> `quit=1`)
 * so even the worst case can't trip an interactive prompt.
 *
 * Installed (by agent-codespaces, with the extension's node shebang) at both
 * ~/ado-auth-helper and ~/azure-auth-helper. The real auth-helper.js branches
 * on the invoked basename, which is preserved because this wrapper IS that
 * path -- so requiring it yields the correct ADO vs Azure behavior.
 *
 * marker: ado-auth-helper-relay  (used by the provisioner to detect our own
 * wrapper and avoid backing it up over the real native helper)
 */
"use strict";

const cp = require("child_process");
const fs = require("fs");
const os = require("os");
const path = require("path");

const HOME = os.homedir();
const DEFAULT_RELAY_PORT = 9857;
const RELAY_CLIENT = path.join(HOME, ".local", "bin", "ado-auth-helper-relay");
const EXT_PREFIX = "ms-codespaces-tools.ado-codespaces-auth";

// When neither the relay nor the VS Code helper is available yet, callers like
// `setup-agency` / `external-git` call us ONCE and, on failure, fall through to
// a plain-git `Username:` prompt that HANGS. So instead of hard-failing we BLOCK
// (bounded poll) until one becomes serviceable -- absorbing the wait so the
// caller's single call succeeds. The deadline matches external-git's own 120s
// tolerance for the helper to appear; the poll interval keeps it responsive.
// Overridable via env for tuning/tests.
const WAIT_DEADLINE_MS = Number(process.env.ADO_AUTH_HELPER_WAIT_MS || 120000);
const POLL_INTERVAL_MS = Number(process.env.ADO_AUTH_HELPER_POLL_MS || 2000);

function isExecutable(p) {
  try { fs.accessSync(p, fs.constants.X_OK); return true; } catch (e) { return false; }
}

// Synchronous sleep (no event loop available in this one-shot helper).
function sleepMs(ms) {
  try {
    Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
  } catch (e) {
    cp.spawnSync("sleep", [String(Math.max(0, ms) / 1000)]);
  }
}

// Resolve the active relay port: explicit env var, else probe the default
// port (the tunnel may be up without this shell inheriting the env var, e.g.
// postCreateCommand / cron). Returns "" when no relay is available.
function relayPort() {
  const env = process.env.LC_GIT_CREDENTIAL_RELAY;
  if (env) return env;
  const probe = cp.spawnSync(
    "bash", ["-c", "exec 3<>/dev/tcp/127.0.0.1/" + DEFAULT_RELAY_PORT],
    { stdio: "ignore" }
  );
  return probe.status === 0 ? String(DEFAULT_RELAY_PORT) : "";
}

// Delegate to the relay client, passing through argv/stdio and exit code.
function useRelay(port) {
  const env = Object.assign({}, process.env, { LC_GIT_CREDENTIAL_RELAY: port });
  const r = cp.spawnSync(RELAY_CLIENT, process.argv.slice(2), {
    stdio: "inherit", env,
  });
  process.exit(typeof r.status === "number" ? r.status : 1);
}

// Find the REAL extension auth-helper.js at runtime.
function findRealHelper() {
  // 1) Reuse the require() target recorded in a backed-up native shim, if it
  //    still exists (fast path, exact match the extension last wrote).
  const backups = [
    path.join(HOME, ".ado-auth-helper-vscode"),
    path.join(HOME, ".azure-auth-helper-vscode"),
  ];
  for (const b of backups) {
    try {
      const m = fs.readFileSync(b, "utf8").match(/require\(["'](.+?)["']\)/);
      if (m && fs.existsSync(m[1])) return m[1];
    } catch (e) { /* ignore */ }
  }
  // 2) Glob the VS Code Server extension roots for the live auth-helper.js,
  //    preferring the highest (latest) version directory.
  const roots = [
    path.join(HOME, ".vscode-remote", "extensions"),
    path.join(HOME, ".vscode-server", "extensions"),
    path.join(HOME, ".vscode-server-insiders", "extensions"),
  ];
  let best = null;
  for (const root of roots) {
    let names;
    try { names = fs.readdirSync(root); } catch (e) { continue; }
    for (const name of names) {
      if (name.indexOf(EXT_PREFIX) !== 0) continue;
      const js = path.join(root, name, "out", "auth-helper.js");
      if (fs.existsSync(js) && (!best || name > best.name)) {
        best = { name: name, js: js };
      }
    }
  }
  return best ? best.js : null;
}

// Hand off to the real VS Code helper as the main module. Returns false if it
// isn't available/loadable yet (extension still initializing), true if it ran
// (it typically exits the process itself).
function tryRealHelper() {
  const real = findRealHelper();
  if (!real) return false;
  // process.argv[1] is this wrapper's path (~/ado-auth-helper or
  // ~/azure-auth-helper), so the real helper sees the correct invoked name.
  require(real);
  return true;
}

// Fail WITHOUT tripping an interactive git prompt. For the git-credential `get`
// action, emit `quit=1` so git stops the helper chain instead of falling back
// to a `Username:`/`Password:` terminal prompt (which hangs headless). Other
// actions (e.g. `get-access-token`) just exit non-zero.
function failQuietly(msg) {
  const action = process.argv[2] || "";
  if (action === "get") process.stdout.write("quit=1\n");
  process.stderr.write("ado-auth-helper: " + msg + "\n");
  process.exit(1);
}

// Relay-first, then the VS Code helper; if NEITHER is ready yet, block and
// re-check until one becomes serviceable or the deadline passes -- so a caller
// that only calls us once (setup-agency / external-git) waits through the
// relay-down / VS-Code-still-initializing window instead of hard-failing into a
// git prompt hang.
const deadline = Date.now() + WAIT_DEADLINE_MS;
let waited = false;
for (;;) {
  const port = relayPort();
  if (port && isExecutable(RELAY_CLIENT)) {
    useRelay(port); // exits
  }
  try {
    if (tryRealHelper()) return; // ran the real helper (usually exits)
  } catch (e) {
    // Extension present but not serving yet (host still coming up) -- keep
    // polling; a later attempt succeeds once it's ready.
  }
  if (Date.now() >= deadline) break;
  waited = true;
  sleepMs(POLL_INTERVAL_MS);
}

failQuietly(
  waited
    ? "timed out waiting for the credential relay or VS Code auth-helper"
    : "relay unavailable and no VS Code auth-helper found"
);
