{
  "version": 1,
  "hooks": {
    "sessionEnd": [
      {
        "type": "command",
        "bash": "s=\"$HOME/.local/bin/session-sync\"; [ -x \"$s\" ] && ( cd \"${TMPDIR:-/tmp}\" && nohup \"$s\" run --detach >/dev/null 2>&1 </dev/null & )",
        "powershell": "$b = Join-Path $env:USERPROFILE '.local\\bin\\session-sync.cmd'; if (Test-Path $b) { Start-Process -FilePath $b -ArgumentList 'run','--detach' -WorkingDirectory $env:TEMP -WindowStyle Hidden }",
        "timeoutSec": 5
      }
    ]
  }
}
