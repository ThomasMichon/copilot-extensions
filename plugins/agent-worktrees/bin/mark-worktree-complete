#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${WORKTREE_PROJECT:-}" ]]; then
    echo "ERROR: WORKTREE_PROJECT is not set. Use the project-specific binstub or export WORKTREE_PROJECT." >&2
    exit 1
fi

# Resolve runtime
if [[ -x "$HOME/.agent-worktrees/.venv/bin/python" ]]; then
    PYTHON="$HOME/.agent-worktrees/.venv/bin/python"
    export PYTHONPATH="$HOME/.agent-worktrees/lib"
else
    echo "ERROR: Venv not found. Run the installer first." >&2
    exit 1
fi

unset PYTHONHOME
exec "$PYTHON" -m agent_worktrees mark-complete "$@"
