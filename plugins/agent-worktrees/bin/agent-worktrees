#!/usr/bin/env bash
set -euo pipefail

# Note: unlike a project binstub, WORKTREE_PROJECT may be unset here.
# We do NOT balk -- the Python entrypoint detects the missing project
# context and prints help + a recommended next step (see cmd_help_unrouted).

# Dual-layout: prefer new runtime, fall back to legacy
if [[ -x "$HOME/.agent-worktrees/.venv/bin/python" ]]; then
    PYTHON="$HOME/.agent-worktrees/.venv/bin/python"
    export PYTHONPATH="$HOME/.agent-worktrees/lib"
else
    echo "ERROR: Venv not found. Run the installer first." >&2
    exit 1
fi

unset PYTHONHOME
export PYTHONUTF8=1
exec "$PYTHON" -m agent_worktrees "$@"
